---
import MainLayout from '../../layouts/MainLayout.astro';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const hasImage = project.image && project.image.trim() !== '';
---

<MainLayout title={project.title} description={project.description} detail>
  <section class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-6 pt-24 pb-16 max-w-4xl">

      <!-- Section 1 — Hero -->
      <a href="/" class="inline-flex items-center gap-2 text-gray-400 hover:text-navy transition-colors mb-10 text-sm font-medium group">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Kembali
      </a>

      <div class="space-y-4">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-800 leading-tight">{project.title}</h1>
        <div class="flex flex-wrap gap-3">
          {project.githubUrls && project.githubUrls.length > 0 && project.githubUrls.map((url) => (
            <a href={url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-gray-900 text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          ))}
          {project.websiteUrl && (
            <a href={project.websiteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-soft-blue text-white px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-soft-blue-dark transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              Website
            </a>
          )}
          {project.prototypeUrl && (
            <a href={project.prototypeUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-navy/20 text-navy px-5 py-2.5 rounded-xl text-sm font-medium hover:bg-navy/5 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              Prototype
            </a>
          )}
        </div>
      </div>

      <!-- Section 2 — Project Image -->
      <div class="mt-8 rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
        {hasImage ? (
          <img src={project.image} alt={project.title} class="w-full aspect-video object-cover" loading="eager" />
        ) : (
          <div class="w-full aspect-video bg-gray-100 flex items-center justify-center">
            <p class="text-gray-400 text-sm font-medium">Image not found</p>
          </div>
        )}
      </div>

      <!-- Section 3 — Overview -->
      <div class="mt-8 bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
        <h2 class="text-sm uppercase tracking-wider text-soft-blue font-bold border-l-[3px] border-soft-blue pl-4 py-1 bg-soft-blue/5 rounded-r-lg mb-4">Overview</h2>
        <p class="text-gray-500 text-[15px] leading-relaxed">{project.overview}</p>
      </div>

      <!-- Section 4 — Role -->
      <div class="mt-4 bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
        <h2 class="text-sm uppercase tracking-wider text-soft-blue font-bold border-l-[3px] border-soft-blue pl-4 py-1 bg-soft-blue/5 rounded-r-lg mb-4">Role / Peran</h2>
        <p class="text-gray-800 font-semibold text-lg">{project.role}</p>
      </div>

      <!-- Section 5 — Kontribusi -->
      <div class="mt-4 bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
        <h2 class="text-sm uppercase tracking-wider text-soft-blue font-bold border-l-[3px] border-soft-blue pl-4 py-1 bg-soft-blue/5 rounded-r-lg mb-4">Kontribusi</h2>
        <ul class="space-y-2.5">
          {project.contributions.map((item) => (
            <li class="flex items-start gap-3 text-[15px] text-gray-500 leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 rounded-full bg-soft-blue shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Section 6 — Technologies -->
      <div class="mt-4 bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
        <h2 class="text-sm uppercase tracking-wider text-soft-blue font-bold border-l-[3px] border-soft-blue pl-4 py-1 bg-soft-blue/5 rounded-r-lg mb-4">Tools / Technology Used</h2>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="inline-flex items-center rounded-lg bg-navy/5 border border-navy/10 px-3 py-1.5 text-xs font-medium text-navy">{tech}</span>
          ))}
        </div>
      </div>

      <!-- Section 7 — Result -->
      <div class="mt-4 bg-white rounded-2xl border border-gray-100 p-8 md:p-10 shadow-sm">
        <h2 class="text-sm uppercase tracking-wider text-soft-blue font-bold border-l-[3px] border-soft-blue pl-4 py-1 bg-soft-blue/5 rounded-r-lg mb-4">Result</h2>
        <ul class="space-y-2.5">
          {project.results.map((item) => (
            <li class="flex items-start gap-3 text-[15px] text-gray-500 leading-relaxed">
              <span class="mt-2 w-1.5 h-1.5 rounded-full bg-soft-blue shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>
</MainLayout>
