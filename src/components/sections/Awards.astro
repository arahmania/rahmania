---
import awards from '../../data/awards.json';
const doubledAwards = [...awards, ...awards];
---

<script>
  import { initScrollAnimations } from '../../lib/scrollAnimations';
  initScrollAnimations();
</script>

<section id="awards" class="py-24">
  <div class="w-full px-5 sm:px-8 lg:px-12 xl:px-20 2xl:px-28">
    <div class="max-w-3xl mx-auto text-center space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 opacity-0-initial" data-animate="section-title">
        Penghargaan & Pelatihan
      </h2>
      <div class="w-16 h-0.5 bg-soft-blue mx-auto rounded-full"></div>
    </div>
  </div>

  <div class="mt-12 overflow-hidden">
    <div class="awards-track flex gap-4 w-max">
      {doubledAwards.map((award) => (
        <a
          href={award.link}
          target="_blank"
          rel="noopener noreferrer"
          class="w-[300px] shrink-0 bg-white rounded-xl p-5 border border-gray-100 hover:border-soft-blue/30 transition-colors group"
        >
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-soft-blue/10 flex items-center justify-center shrink-0 group-hover:bg-soft-blue/20 transition-colors">
              <svg class="w-4 h-4 text-soft-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h4 class="text-sm font-semibold text-gray-800 truncate">{award.name}</h4>
                <span class="text-xs text-gray-400 shrink-0">{award.year}</span>
              </div>
              <p class="text-xs text-gray-400 mt-0.5">{award.organizer}</p>
              <p class="text-xs text-gray-500 mt-1 line-clamp-2">{award.description}</p>
            </div>
            <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-soft-blue transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>

  <style>
    .awards-track {
      animation: scroll-awards 30s linear infinite;
    }
    .awards-track:hover {
      animation-play-state: paused;
    }
    @keyframes scroll-awards {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>
</section>
