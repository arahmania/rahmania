---
import skills from '../../data/skills.json';

const categories = [
  {
    key: 'software' as const,
    label: 'Tools',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    color: 'text-soft-blue',
  },
  {
    key: 'development' as const,
    label: 'Pengembangan',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    color: 'text-navy',
  },
  {
    key: 'interpersonal' as const,
    label: 'Interpersonal',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    color: 'text-blue-500',
  },
  {
    key: 'bahasa' as const,
    label: 'Bidang Keahlian',
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    color: 'text-purple-500',
  },
];
---

<script>
  import { initScrollAnimations } from '../../lib/scrollAnimations';
  initScrollAnimations();
</script>

<section id="skills" class="py-24">
  <div class="w-full px-5 sm:px-8 lg:px-12 xl:px-20 2xl:px-28">
    <div class="text-center space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 opacity-0-initial" data-animate="section-title">
        Bidang Keahlian
      </h2>
      <div class="w-16 h-0.5 bg-soft-blue mx-auto rounded-full"></div>
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map((cat) => (
        <div class="border border-gray-200 rounded-xl p-7 transition-all duration-300 hover:border-soft-blue/40 hover:shadow-sm group">
          <div class="flex items-center gap-2.5 mb-4">
            <span class:list={[cat.color]} set:html={cat.icon} />
            <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider">{cat.label}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {skills[cat.key].map((skill) => (
              <span class="inline-flex items-center rounded-md bg-gray-50 border border-gray-100 px-3 py-1.5 text-xs font-medium text-gray-600 group-hover:border-soft-blue/20 transition-colors duration-200">
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
