---
interface Props {
  detail?: boolean;
}

const { detail } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200/30 shadow-sm">
  <div class="w-full px-5 sm:px-8 lg:px-12 xl:px-20 2xl:px-28 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-soft-blue to-navy flex items-center justify-center">
        <span class="text-white font-bold text-sm">AR</span>
      </div>
      <span class="font-semibold text-gray-800 text-lg hidden sm:inline">Rahmania</span>
    </a>

    {detail ? (
      <!-- Detail Page Menu -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Beranda
        </a>
      </div>
    ) : (
      <!-- Menu Desktop -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Tentang
        </a>
        <a href="#experience" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Pengalaman
        </a>
        <a href="#projects" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Proyek
        </a>
        <a href="#skills" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Skill
        </a>
        <a href="#contact" class="text-gray-600 hover:text-navy transition-colors text-sm font-medium">
          Kontak
        </a>
      </div>
    )}

    <!-- CTA Button -->
    <a 
      href="mailto:anisarahmania313@gmail.com"
      class="hidden sm:inline-flex items-center gap-2 px-5 py-2 rounded-full bg-navy text-white text-sm font-medium hover:bg-navy-light transition-colors shadow-md shadow-navy/10"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      Hubungi
    </a>

    <!-- Mobile Menu Button -->
    <button class="md:hidden p-2 hover:bg-gray-100 rounded-lg transition-colors">
      <svg class="w-6 h-6 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</nav>
