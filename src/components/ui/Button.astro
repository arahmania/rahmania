---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 rounded-full px-7 py-3.5 font-medium transition-all duration-300 text-sm';

const variants = {
  primary: 'bg-navy text-white hover:bg-navy-light shadow-md shadow-navy/10 hover:shadow-lg hover:shadow-navy/20 hover:scale-105 hover:-translate-y-0.5',
  secondary: 'bg-soft-blue/10 text-navy hover:bg-soft-blue/20 hover:scale-105 hover:-translate-y-0.5',
  outline: 'border border-gray-200 text-gray-600 hover:border-navy hover:text-navy hover:scale-105 hover:-translate-y-0.5',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
