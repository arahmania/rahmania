---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;
---

<div class:list={[
  'bg-white rounded-2xl p-6 border border-gray-100 opacity-0-initial',
  hover && 'transition-all duration-300 hover:shadow-lg hover:border-soft-blue/30 hover:-translate-y-1 hover:scale-105',
  'data-animate="card"',
  className,
]}>
  <slot />
</div>
